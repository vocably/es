{"transcript":"a.ɣoˈβjan̪.do","exists":true,"definitions":["Causar gran molestia o fatiga.","Preocupar o angustiar intensamente.","Abrumar con un exceso de trabajo o responsabilidades."],"examples":["El calor está agobiando a todos.","Las deudas lo están agobiando.","La presión del examen me está agobiando."],"lemma":"agobiar","lemmaPos":"verb","synonyms":["abrumar","estresar","angustiar","fatigar","preocupar"],"number":"singular","tense":"present","pastTenses":"agobió (simple past), ha agobiado (present perfect)","source":"agobiando"}