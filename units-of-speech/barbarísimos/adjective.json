{"transcript":"baɾbaˈɾisimos","exists":true,"definitions":["Grado superlativo de bárbaro: extremadamente fieros, crueles o temerarios.","Sumamente excelentes, extraordinarios o magníficos.","Muy ignorantes o faltos de cultura."],"examples":["Esos guerreros eran barbarísimos.","Cometieron unos errores barbarísimos.","Vimos unos paisajes barbarísimos."],"lemma":"bárbaro","lemmaPos":"adjective","synonyms":["cruelísimos","ferocísimos","excelentísimos","brutalísimos"],"number":"plural","gender":"masculine","source":"barbarísimos"}