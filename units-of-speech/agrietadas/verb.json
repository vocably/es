{"transcript":"a.ɣɾjeˈta.ðas","exists":true,"definitions":["Que tienen grietas o hendiduras.","Que están cuarteadas o rajadas."],"examples":["Las paredes estaban agrietadas por el terremoto.","Las manos agrietadas del trabajador revelaban su esfuerzo.","Las superficies agrietadas necesitan reparación."],"lemma":"agrietar","lemmaPos":"verb","synonyms":["hender","rajar","cuartear","resquebrajar"],"number":"plural","tense":"past","pastTenses":"agrietaron, han agrietado","gender":"feminine","source":"agrietadas"}