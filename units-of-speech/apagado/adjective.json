{"transcript":"a.paˈɣa.ðo","exists":true,"definitions":["Que está sin luz o fuego.","De poco brillo o intensidad.","Triste, melancólico, sin ánimo.","Dicho de un color, poco vivo o pálido."],"examples":["El fuego está apagado.","Tiene un tono de voz apagado.","Se siente apagado últimamente.","Viste con colores apagados."],"lemma":"apagar","lemmaPos":"verb","synonyms":["extinguido","oscuro","triste","pálido"],"number":"singular","gender":"masculine","source":"apagado"}